# TMDB API Key — get yours at https://www.themoviedb.org/settings/api
VITE_TMDB_KEY=YOUR_TMDB_API_KEY_HERE
REACT_APP_TMDB_KEY=YOUR_TMDB_API_KEY_HERE

# (Vercel only) Allowed origin for CORS — set to your deployed domain
# Example: https://cineverse.vercel.app
ALLOWED_ORIGIN=https://your-domain.vercel.app
